APP_NAME=AI Powered Dashboard API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8418
PROCESSED_DATA_DIR=/app/data/processed
BACKEND_CORS_ORIGINS=http://localhost:3418
ALLOWED_HOSTS=localhost,127.0.0.1,backend,testserver
NEXT_PUBLIC_API_BASE_URL=http://localhost:8418
FRONTEND_PORT=3418
BACKEND_PORT=8418
LLM_ENABLED=true
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=20
LLM_REASONING_EFFORT=low
LLM_MAX_OUTPUT_TOKENS=520
LLM_MAX_EVIDENCE_ITEMS=5
LLM_MAX_WARNING_ITEMS=4
LLM_EXTERNAL_CONTEXT_MAX_CHARS=600
CHAT_AUTO_LLM=true
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_DB_PATH=/app/.local/chat_memory.sqlite3
CHAT_MEMORY_MAX_TURNS=8
